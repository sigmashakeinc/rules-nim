# nim_write_safety.rules
# Technology: nim | Capability: write

rule nim-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "cast["
  MESSAGE "Blocked an unsafe pattern in nim. Use the recommended best practices for 2025/2026."
}

rule nim-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "system.alloc"
  MESSAGE "You are using an outdated API for nim. Please upgrade to the newer API."
}
